{
  "name": "agent-log-gif",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/New_York}"
    }
  },
  "userEnvProbe": "none",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "charliemarsh.ruff",
        "eamodio.gitlens",
        "iwyvi.chinolor"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliemarsh.ruff",
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=alg-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=alg-claude-config-${devcontainerId},target=/home/node/.claude,type=volume",
    "source=alg-codex-config-${devcontainerId},target=/home/node/.codex,type=volume",
    "source=alg-node-modules-${devcontainerId},target=/workspace/node_modules,type=volume",
    "source=alg-venv-${devcontainerId},target=/workspace/.venv_devcontainer,type=volume",
    "source=uv-cache-${localEnv:UV_CACHE_ARCH:linux-arm64},target=/home/node/.cache/uv,type=volume"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "AGENT_BROWSER_EXECUTABLE_PATH": "/home/node/.local/bin/playwright-chromium"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  // configure Playwright test chromium; point agent-browser to a stable symlink
  // so later shells and tools can reuse the same installed browser without
  // depending on an ephemeral export from this command.
  "postStartCommand": "mise trust && uv sync && uv run playwright install chromium && mkdir -p ~/.local/bin && CHROME=$(find ~/.cache/ms-playwright/chromium-*/chrome-linux/chrome -maxdepth 0 2>/dev/null | head -1) && test -n \"$CHROME\" && ln -sf \"$CHROME\" ~/.local/bin/playwright-chromium && git config core.hooksPath .githooks",
  "waitFor": "postStartCommand"
}
